---
name: "supertrend-filtered"
description: "Supertrend trend-following with RSI confirmation"
author: "template"
operator: "templates"
created: "2026-01-01T00:00:00Z"
tags:
  - supertrend
  - trend-following
  - rsi-confirmation
  - template
parent: null
hash: ""
attestation:
  status: "unattested"
runtime: "freqtrade"
sdna_version: "0.1"
---
{
  "signals": {
    "entry_long": {
      "type": "composite_and",
      "conditions": [
        {
          "type": "custom",
          "expression": "dataframe['supertrend_direction'] == 1"
        },
        {
          "type": "threshold_cross",
          "indicator": "rsi",
          "params": { "period": 14 },
          "condition": "below",
          "value": 60
        }
      ]
    },
    "exit_long": {
      "type": "custom",
      "expression": "dataframe['supertrend_direction'] == -1"
    },
    "entry_short": {
      "type": "composite_and",
      "conditions": [
        {
          "type": "custom",
          "expression": "dataframe['supertrend_direction'] == -1"
        },
        {
          "type": "threshold_cross",
          "indicator": "rsi",
          "params": { "period": 14 },
          "condition": "above",
          "value": 40
        }
      ]
    },
    "exit_short": {
      "type": "custom",
      "expression": "dataframe['supertrend_direction'] == 1"
    }
  },
  "regime_filter": {
    "enabled": false,
    "detector": null,
    "params": {},
    "allowed_regimes": []
  },
  "risk": {
    "position_size": {
      "method": "fixed_stake",
      "amount_usdt": 100
    },
    "stop_loss": {
      "method": "atr_multiple",
      "params": { "period": 14, "multiplier": 3.0 }
    },
    "take_profit": {
      "method": "risk_reward",
      "params": { "ratio": 2.0 }
    },
    "max_drawdown": 0.20,
    "max_open_trades": 3
  },
  "pairs": ["BTC/USDT"],
  "timeframe": "4h",
  "informative_timeframes": [],
  "exchange": {
    "name": "binance",
    "trading_mode": "futures",
    "margin_mode": "isolated"
  }
}
