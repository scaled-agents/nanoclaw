{
  "_comment": "Reference defaults for all tunable thresholds. Copy to {WORKSPACE}/scoring-config.json to override. Keys match docs/execution-gates.md and docs/portfolio-rules.md.",

  "COMPOSITE_WEIGHTS": {
    "regime_fit": 0.4,
    "execution_fit": 0.25,
    "net_edge": 0.35
  },

  "DEPLOY_THRESHOLD": 3.5,
  "UNDEPLOY_THRESHOLD": 2.0,

  "SIGNAL_HYSTERESIS_TICKS": 2,

  "MACRO_OVERLAY": {
    "risk_off_penalty": -0.5,
    "risk_on_trend_boost": 0.3,
    "sentiment_extreme_penalty": -0.5,
    "narrative_alignment_boost": 0.2
  },

  "PORTFOLIO_CONSTRAINTS": {
    "_comment": "Slot Management spec lowered max_total_deployments from 20 → 10 (hard cap, see SLOT_MANAGEMENT.max_total_bots). max_per_archetype/pair remain as soft caps; max_per_group is the structural diversification constraint.",
    "max_per_archetype": 5,
    "max_per_pair": 3,
    "max_total_deployments": 10,
    "max_capital_per_deployment_pct": 10,
    "max_capital_per_archetype_pct": 25,
    "max_capital_per_pair_pct": 15
  },

  "SLOT_MANAGEMENT": {
    "_comment": "10-bot slot lifecycle. Trial bots have hard deadlines and easy eviction; graduated bots earn protection but can be replaced when degrading. All values tunable by gate kata.",
    "max_total_bots": 10,
    "max_trial_bots": 5,
    "trial_deadlines_days": {
      "5m": 2,
      "15m": 3,
      "1h": 7,
      "4h": 14
    },
    "trial_early_eviction": {
      "zero_trades_hours": 48,
      "near_dead_trades": 1,
      "near_dead_hours": 72,
      "min_win_rate_n": 5,
      "min_win_rate_floor": 0.20,
      "max_divergence": 0.70,
      "max_loss_pct": -5.0
    },
    "graduation_gates": {
      "min_win_rate": 0.35,
      "min_favorable_sharpe": 0.30,
      "min_risk_reward_ratio": 0.80,
      "max_consecutive_losses": 4,
      "max_divergence": 0.50,
      "min_trades": {
        "5m": 20,
        "15m": 15,
        "1h": 10,
        "4h": 5
      }
    },
    "eviction_weights": {
      "trial_base": 100,
      "dead_bot_bonus": 50,
      "low_win_rate_bonus": 30,
      "high_divergence_bonus": 20,
      "expired_per_day": 10,
      "promising_protection": -20,
      "near_graduation_protection": -30,
      "graduated_base": 0,
      "degrading_win_rate": 30,
      "degrading_divergence": 20,
      "anti_regime": 40,
      "regime_fault_paused": 50,
      "diversity_protection": -30,
      "strong_performer_protection": -20,
      "tenure_protection": -10
    },
    "replacement_sharpe_threshold": 0.20,
    "max_per_group": 4,
    "group_balance": {
      "trend": { "target": 3, "min": 1 },
      "range": { "target": 3, "min": 1 },
      "vol":   { "target": 2, "min": 1 },
      "carry": { "target": 1, "min": 0 }
    },
    "candidate_quality_multipliers": {
      "kata_graduated": 1.5,
      "qualifier": 1.2,
      "untested": 1.0
    }
  },

  "CIRCUIT_BREAKER": {
    "dd_threshold_pct": 15
  },

  "SENTIMENT_MULTIPLIER": {
    "floor": 0.4,
    "scaling_factor": 0.6
  },

  "DIVERGENCE_GATE": {
    "enabled": true,
    "min_trades": 10,
    "route_threshold": 0.30,
    "pause_threshold": 0.70
  },

  "RETIREMENT_GATES": {
    "catastrophic_dd_multiplier": 1.5,
    "catastrophic_dd_multiplier_high_regime_dep": 1.0,
    "consecutive_losses_count": 5,
    "consecutive_losses_pct": 5,
    "dead_container_consecutive_checks": 2,
    "win_rate_floor": 0.25,
    "win_rate_floor_low_rr_archetypes": 0.20,
    "rr_inversion_win_rate_min": 0.45,
    "rr_inversion_pnl_threshold": -1.0
  },

  "GRADUATION_GATES": {
    "min_live_sharpe_default": 0.5,
    "max_drawdown_pct_default": 15,
    "publishing_sharpe_threshold": 0.8,
    "min_win_rate": 0.35,
    "min_win_rate_low_rr_archetypes": 0.28,
    "min_rr_ratio": 0.8,
    "max_consecutive_losses": 4
  },

  "OVERFITTING_GATES": {
    "_comment": "Bailey & Lopez de Prado statistical-significance gates. DSR ≥ 1.96 means observed Sharpe is significant at 5% after correcting for selection bias from n_strategies_tried. PBO ≤ 0.30 means probability of backtest overfitting is acceptable. PBO > 0.50 forces immediate eviction. min_trades_for_dsr prevents the gate from blocking on day 1 when DSR has huge standard error.",
    "enabled": true,
    "dsr_threshold": 1.96,
    "pbo_max": 0.30,
    "pbo_evict": 0.50,
    "deadline_extension_on_low_dsr": 1.5,
    "min_trades_for_dsr": 10,
    "min_kata_experiments_for_dsr_enforcement": 5
  },

  "EXECUTION_GATES": {
    "_comment": "Slippage-aware graduation (Finding 12). execution_quality = 1 - (avg_slippage / avg_abs_pnl), clamped to [0,1]. Three-tier fallback: shortfall (decision benchmark) > measured (placement slippage) > estimated (volume_weight tier). Pause-not-retire on collapse: the strategy is fine in theory, the venue is wrong. estimated_slippage_bps is last-resort fallback when measured data is unavailable.",
    "enabled": true,
    "min_execution_quality": 0.60,
    "pause_threshold": 0.50,
    "slippage_pnl_ratio_max": 0.50,
    "min_trades_for_gate": 10,
    "estimated_slippage_bps": {
      "high_liquidity": 1,
      "medium_liquidity": 3,
      "low_liquidity": 7
    },
    "volume_weight_thresholds": {
      "high": 0.70,
      "medium": 0.30
    }
  },

  "DEPLOY_VERIFICATION": {
    "enabled": true,
    "min_win_rate": 0.30,
    "lookback_days": 30,
    "max_per_tick": 3
  },

  "GAP_SCORING_WEIGHTS": {
    "COMPOSITE_SCORE": 2.0,
    "GROUP_DIVERSITY": 5.0,
    "ARCHETYPE_ZERO_COVERAGE": 3.0,
    "TIMEFRAME_FREQUENCY": 2.0,
    "REGIME_MATCH": 3.0,
    "QUALIFIER_BOOST": 3.0,
    "EDGE_BONUS_HIGH": 2.0,
    "EDGE_BONUS_MID": 1.0,
    "DEPLOYMENT_FAILURE_PENALTY": -3.0,
    "DEPLOYMENT_FAILURE_BLACKLIST_THRESHOLD": 3,
    "DEPLOYMENT_FAILURE_BLACKLIST_SCORE": -10.0,
    "DEPLOYMENT_FAILURE_LOOKBACK_DAYS": 14,
    "DEPLOYMENT_CHURN_PENALTY_PER_CYCLE": -1.0,
    "DEPLOYMENT_CHURN_CAP": -5.0,
    "PERSISTENCE_BONUS_PER_SNAPSHOT": 0.5,
    "PERSISTENCE_CAP": 3.0,
    "ABANDONED_CAMPAIGN_PENALTY": -2.0,
    "ACTIVE_CAMPAIGN_BONUS": 1.0,
    "FAR_FROM_DEPLOY_PENALTY": -2.0,
    "STABILITY_WEIGHT": 1.5,
    "FALLING_TREND_PENALTY": -0.5,
    "GRADUATION_SPEED_WEIGHT": 2.0,
    "ANTI_REGIME_PENALTY": -5.0,
    "ACTIVE_KATA_PENALTY": -10.0,
    "ACTIVE_TRIAGE_PENALTY": -8.0,
    "NO_CELL_DATA_PENALTY": -10.0
  },

  "TIMEFRAME_FREQUENCY_BONUS": {
    "5m": 1.0,
    "15m": 1.0,
    "1h": 0.7,
    "4h": 0.3
  },

  "NET_EDGE_REBALANCE": {
    "enabled_when_all_zero": true,
    "adjusted_weights": {
      "regime_fit": 0.62,
      "execution_fit": 0.38
    }
  },

  "VOLUME_WEIGHT": {
    "normalization": "max_liquidity_percentile"
  },

  "VOLUME_WEIGHTED_STAKE": {
    "_comment": "Finding 13 — scale deployment stake by liquidity. effective_stake_pct = clamp(base_stake_pct * (volume_weight / portfolio_avg_volume_weight), base*floor, base*ceiling). Disabled → use base_stake_pct flat.",
    "enabled": true,
    "floor_multiplier": 0.4,
    "ceiling_multiplier": 1.5,
    "default_portfolio_avg_volume_weight": 0.65
  },

  "TREND_BOOST": {
    "rising_threshold": 0.3,
    "rising_boost": 0.2,
    "falling_threshold": -0.3,
    "falling_penalty": -0.1
  }
}
